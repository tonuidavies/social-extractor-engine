<?xml version="1.0" encoding="UTF-8"?>

<configuration scan="true" scanPeriod="30 seconds">

    <property name="LOG_DIR"    value="${LOG_DIR:-logs}"/>
    <property name="APP_LEVEL"  value="${APP_LEVEL:-INFO}"/>
    <property name="ROOT_LEVEL" value="${ROOT_LEVEL:-INFO}"/>

    <!-- Compact, colored pattern for the console. Stack traces auto-append. -->
    <property name="CONSOLE_PATTERN"
              value="%gray(%d{HH:mm:ss.SSS}) %highlight(%-5level) %cyan(%-34.34logger{34}) %gray(|) %msg%n"/>

    <!-- Full, plain pattern for files (thread included for reactive debugging). -->
    <property name="FILE_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{48} | %msg%n"/>

    <!-- ============================ APPENDERS ============================ -->

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- All logs, rolling by day and size, gzip-compressed, capped. -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/app.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/app-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>14</maxHistory>
            <totalSizeCap>500MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${FILE_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- WARN+ only, so failures are easy to find. -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/error.log</file>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>WARN</level>
        </filter>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/error-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>200MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${FILE_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- Non-blocking file writes (nice for a reactive app under load). -->
    <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
        <appender-ref ref="FILE"/>
        <queueSize>1024</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <neverBlock>true</neverBlock>
    </appender>

    <!-- ============================ LOGGERS ============================= -->

    <!-- Your code — bump to DEBUG via APP_LEVEL=DEBUG when investigating. -->
    <logger name="com.socials.extractor" level="${APP_LEVEL}"/>

    <!-- Quiet the noisy libraries. -->
    <logger name="reactor.netty"            level="WARN"/>
    <logger name="io.netty"                 level="WARN"/>
    <logger name="reactor.core"             level="WARN"/>
    <logger name="com.microsoft.playwright" level="WARN"/>
    <logger name="org.springframework"      level="INFO"/>
    <logger name="org.springframework.web"  level="INFO"/>
    <logger name="org.mongodb"              level="WARN"/>
    <logger name="org.apache"               level="WARN"/>

    <root level="${ROOT_LEVEL}">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="ASYNC_FILE"/>
        <appender-ref ref="ERROR_FILE"/>
    </root>

</configuration>
